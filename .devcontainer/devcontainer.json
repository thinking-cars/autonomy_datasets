{

  // set UI container name
  "name": "${localWorkspaceFolderBasename}",

  // run script to automatically infer base image from the VS Code workspace where this is integrated
  "initializeCommand": [".openads-dev-environment/.devcontainer/build-local-dockerfile.sh"],

  // build dev image from automatically generated Dockerfile (see build-local-dockerfile.sh);
  // the Dockerfile is necessary to create the dockeruser from the original entrypoint of the base image;
  // the original entrypoint is overridden by the devcontainer extension
  "build": {
    "dockerfile": "Dockerfile.local"
  },

  "containerEnv": {
    // allow global pip installs in dev container (required by rosdep)
    "PIP_BREAK_SYSTEM_PACKAGES": "1"
  },

  // launch dev container as dockeruser
  "containerUser": "dockeruser",

  // mount VS Code workspace to docker-ros workspace
  "workspaceMount": "source=${localWorkspaceFolder},target=/docker-ros/ws/src/target,type=bind",
  "workspaceFolder": "/docker-ros/ws/src/target",

  // mount host AI auth/config into container to persist login
  "mounts": [
    "source=${localEnv:HOME}/.claude,target=/home/dockeruser/.claude,type=bind",
    "source=${localEnv:HOME}/.codex,target=/home/dockeruser/.codex,type=bind",
    "source=${localEnv:HOME}/datasets,target=/datasets,type=bind"
  ],

  "runArgs": [
    // enable GUI support
    "--env=DISPLAY",
    "--volume=/tmp/.X11-unix:/tmp/.X11-unix:rw",

    // enable GPU support
    "--gpus", "all",

    // attach to external Zenoh router if devcontainer should connect to other containers
    //"--network=TODO",
    //"--env", "RMW_IMPLEMENTATION=rmw_zenoh_cpp",
    //"--env", "ZENOH_CONFIG_OVERRIDE=connect/endpoints=[\"tcp/zenoh-router:7447\"]",
  ],

  // https://containers.dev/features
  "features": {},

  // VS Code settings and extensions
  "customizations": {
    "vscode": {
      "settings": {
        "ROS2.rosSetupScript": "/docker-ros/ws/install/setup.bash"
      },
      "extensions": [
        "althack.ament-task-provider",
        "anthropic.claude-code",
        "charliermarsh.ruff",
        "cschlosser.doxdocgen",
        "github.copilot-chat",
        "github.copilot",
        "google.geminicodeassist",
        "mhutchie.git-graph",
        "ms-azuretools.vscode-containers",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-vscode-remote.vscode-remote-extensionpack",
        "ms-vscode.cpp-devtools",
        "ms-vscode.cpptools-themes",
        "ms-vscode.cpptools",
        "njpwerner.autodocstring",
        "openai.chatgpt",
        "Ranch-Hand-Robotics.rde-pack"
      ]
    }
  }
}